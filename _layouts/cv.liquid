---
layout: default
---
{% assign use_jsonresume = false %}
{% if page.cv_format == 'jsonresume' %}
  {% assign use_jsonresume = true %}
{% elsif page.cv_format == 'rendercv' %}
  {% assign use_jsonresume = false %}
{% elsif site.data.resume %}
  {% assign use_jsonresume = true %}
{% endif %}

{% unless use_jsonresume %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">
        {{ page.title }}
        {% if page.cv_pdf %}
          <a
            {% if page.cv_pdf contains '://' %}
              href="{{ page.cv_pdf }}"
            {% else %}
              href="{{ page.cv_pdf | relative_url }}"
            {% endif %}
            target="_blank"
            rel="noopener noreferrer"
            class="float-right"
          >
            <i class="fa-solid fa-file-pdf"></i>
          </a>
        {% endif %}
      </h1>
      {% if page.description %}
        <p class="post-description">{{ page.description }}</p>
      {% endif %}
    </header>

    <article>
      <div class="cv">
        {% assign rendercv = site.data.cv.cv %}
        {% if rendercv %}
          <div class="card mt-3 p-3">
            <h3 class="card-title font-weight-medium">Profile</h3>
            <div>
              {% if rendercv.name %}
                <p><strong>{{ rendercv.name }}</strong>{% if rendercv.label %} - {{ rendercv.label }}{% endif %}</p>
              {% endif %}
              {% if rendercv.summary %}
                <p>{{ rendercv.summary }}</p>
              {% endif %}
              {% if rendercv.email or rendercv.location %}
                <p>
                  {% if rendercv.email %}{{ rendercv.email }}{% endif %}
                  {% if rendercv.email and rendercv.location %} | {% endif %}
                  {% if rendercv.location %}{{ rendercv.location }}{% endif %}
                </p>
              {% endif %}
            </div>
          </div>

          {% for section in rendercv.sections %}
            <a class="anchor" id="{{ section[0] | slugify }}"></a>
            <div class="card mt-3 p-3">
              <h3 class="card-title font-weight-medium">{{ section[0] }}</h3>
              <div>
                {% for item in section[1] %}
                  <div class="mb-2">
                    {% if item.institution %}
                      <p><strong>{{ item.institution }}</strong>{% if item.studyType %} - {{ item.studyType }}{% endif %}{% if item.area %}, {{ item.area }}{% endif %}</p>
                    {% elsif item.company %}
                      <p><strong>{{ item.company }}</strong>{% if item.position %} - {{ item.position }}{% endif %}</p>
                    {% elsif item.name %}
                      <p><strong>{{ item.name }}</strong>{% if item.level %} - {{ item.level }}{% endif %}</p>
                    {% endif %}

                    {% if item.location or item.start_date or item.end_date %}
                      <p>
                        {% if item.location %}{{ item.location }}{% endif %}
                        {% if item.location and item.start_date %} | {% endif %}
                        {% if item.start_date %}{{ item.start_date }}{% endif %}{% if item.end_date %} - {{ item.end_date }}{% endif %}
                      </p>
                    {% endif %}

                    {% if item.summary %}
                      <p>{{ item.summary }}</p>
                    {% endif %}

                    {% if item.highlights %}
                      <ul>
                        {% for highlight in item.highlights %}
                          <li>{{ highlight }}</li>
                        {% endfor %}
                      </ul>
                    {% endif %}

                    {% if item.keywords %}
                      <p>{{ item.keywords | join: ', ' }}</p>
                    {% endif %}
                  </div>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% else %}
          {% for entry in site.data.cv %}
            <a class="anchor" id="{{ entry.title }}"></a>
            <div class="card mt-3 p-3">
              <h3 class="card-title font-weight-medium">{{ entry.title }}</h3>
              <div>
                {% if entry.type == 'list' %}
                  {% include cv/list.liquid %}
                {% elsif entry.type == 'map' %}
                  {% include cv/map.liquid %}
                {% elsif entry.type == 'nested_list' %}
                  {% include cv/nested_list.liquid %}
                {% elsif entry.type == 'time_table' %}
                  {% include cv/time_table.liquid %}
                {% elsif entry.type == 'list_groups' %}
                  {% include cv/list_groups.liquid %}
                {% else %}
                  {{ entry.contents }}
                {% endif %}
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </article>
  </div>
{% else %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">
        {{ page.title }}
        {% if page.cv_pdf %}
          <a
            {% if page.cv_pdf contains '://' %}
              href="{{ page.cv_pdf }}"
            {% else %}
              href="{{ page.cv_pdf | relative_url }}"
            {% endif %}
            target="_blank"
            rel="noopener noreferrer"
            class="float-right"
          >
            <i class="fa-solid fa-file-pdf"></i>
          </a>
        {% endif %}
      </h1>
      {% if page.description %}
        <p class="post-description">{{ page.description }}</p>
      {% endif %}
    </header>

    <article>
      <div class="cv">
        {% for data in site.data.resume %}
          {% if site.jsonresume and site.jsonresume.size > 0 %}
            {% unless site.jsonresume contains data[0] %}
              {% continue %}
            {% endunless %}
          {% endif %}
          {% if data[0] == 'meta' or data[1].size == 0 %} {% continue %} {% endif %}
          <a class="anchor" id="{{ data[0] }}"></a>
          <div class="card mt-3 p-3">
            <h3 class="card-title font-weight-medium">{{ data[0] | capitalize }}</h3>
            <div>
              {% case data[0] %}
                {% when 'basics' %}
                  {% include resume/basics.liquid %}
                {% when 'education' %}
                  {% include resume/education.liquid %}
                {% when 'work' %}
                  {% include resume/work.liquid %}
                {% when 'volunteer' %}
                  {% include resume/volunteer.liquid %}
                {% when 'projects' %}
                  {% include resume/projects.liquid %}
                {% when 'awards' %}
                  {% include resume/awards.liquid %}
                {% when 'skills' %}
                  {% include resume/skills.liquid %}
                {% when 'publications' %}
                  {% include resume/publications.liquid %}
                {% when 'languages' %}
                  {% include resume/languages.liquid %}
                {% when 'interests' %}
                  {% include resume/interests.liquid %}
                {% when 'certificates' %}
                  {% include resume/certificates.liquid %}
                {% when 'references' %}
                  {% include resume/references.liquid %}
                {% else %}

              {% endcase %}
            </div>
          </div>
        {% endfor %}
      </div>
    </article>
  </div>
{% endunless %}
